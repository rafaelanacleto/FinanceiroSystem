{
  "mcpServers": {
    "financeiro-sqlserver": {
      "command": "/home/rafaelanacleto/.nvm/versions/node/v24.18.0/bin/npx",
      "args": ["-y", "@connorbritain/mssql-mcp-reader@latest"],
      "env": {
        "SERVER_NAME": "localhost",
        "SQL_PORT": "1433",
        "DATABASE_NAME": "financeiro",
        "SQL_AUTH_MODE": "sql",
        "SQL_USERNAME": "sa",
        "SQL_PASSWORD": "YOUR_SA_PASSWORD",
        "TRUST_SERVER_CERTIFICATE": "true",
        "READONLY": "true"
      }
    },
    "dotnet": {
      "command": "dnx",
      "args": ["Community.Mcp.DotNet@1.*", "--yes"],
      "cwd": "/home/rafaelanacleto/repos/FinanceiroSystem"
    }
  }
}
